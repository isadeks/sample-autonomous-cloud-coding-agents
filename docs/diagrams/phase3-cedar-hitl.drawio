        </mxCell>
        <mxCell id="rtjwt-i" parent="rtjwt" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.bedrock_agentcore;fillColor=#01A88D;strokeColor=#ffffff;aspect=fixed;html=1;verticalAlign=top;align=center;fontSize=10;fontFamily=Helvetica;" value="" vertex="1">
          <mxGeometry height="48" width="48" x="14" y="34" as="geometry" />
        </mxCell>
        <mxCell id="pe" parent="rtjwt" style="rounded=1;fillColor=light-dark(#EDE7F6,#1a1530);strokeColor=#8C4FFF;strokeWidth=2;html=1;verticalAlign=top;fontSize=11;fontStyle=1;fontColor=#8C4FFF;fontFamily=Helvetica;spacing=6;whiteSpace=wrap;" value="⚙️ PolicyEngine (extended)&#10;&lt;span style=&quot;font-weight:normal;font-size:9px&quot;&gt;&#10;• HARD_DENY_POLICIES (was: all forbid rules)&#10;• SOFT_DENY_POLICIES (NEW, @tier(&quot;soft&quot;))&#10;• in-process allowlist (grows per scope)&#10;• evaluate_tool_use returns: ALLOW | DENY |&#10;   REQUIRE_APPROVAL(reason, timeout_s, severity, rule_ids)&#10;&lt;/span&gt;" vertex="1">
          <mxGeometry height="130" width="330" x="80" y="30" as="geometry" />
        </mxCell>
        <mxCell id="hook" parent="rtjwt" style="rounded=1;fillColor=light-dark(#EDE7F6,#1a1530);strokeColor=#8C4FFF;strokeWidth=2;html=1;verticalAlign=top;fontSize=11;fontStyle=1;fontColor=#8C4FFF;fontFamily=Helvetica;spacing=6;whiteSpace=wrap;" value="⚙️ PreToolUse hook (extended)&#10;&lt;span style=&quot;font-weight:normal;font-size:9px&quot;&gt;&#10;• calls PolicyEngine.evaluate_tool_use&#10;• on REQUIRE_APPROVAL:&#10;   1. mint request_id ULID&#10;   2. PutItem to TaskApprovalsTable&#10;   3. task RUNNING → AWAITING_APPROVAL&#10;   4. emit agent_milestone(&quot;approval_requested&quot;)&#10;   5. poll 2s → 5s (backoff after 30s)&#10;   6. on APPROVED → update allowlist per scope&#10;   7. return allow/deny to SDK&#10;&lt;/span&gt;" vertex="1">
          <mxGeometry height="180" width="330" x="80" y="170" as="geometry" />
        </mxCell>
        <mxCell id="pw" parent="rtjwt" style="text;html=1;fontSize=9;fontFamily=Helvetica;fontColor=#777777;align=left;verticalAlign=top;spacing=4;whiteSpace=wrap;" value="ProgressWriter → TaskEventsTable (DDB)&#10;SSEAdapter → Runtime-JWT SSE stream (Terminal A)" vertex="1">
          <mxGeometry height="40" width="330" x="80" y="360" as="geometry" />
        </mxCell>
