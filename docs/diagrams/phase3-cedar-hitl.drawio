        <mxCell id="p11-phase4" parent="1" style="text;html=1;align=left;fontSize=13;fontStyle=1;fontFamily=Helvetica;fontColor=#2E7D32;" value="── Phase 4: Agent runs terraform — every tool call hits fast-path ──" vertex="1">
          <mxGeometry height="20" width="600" x="60" y="1090" as="geometry" />
        </mxCell>
        <mxCell id="p11-m16" parent="1" style="html=1;endArrow=classic;strokeColor=#8C4FFF;strokeWidth=2;fontColor=#8C4FFF;fontSize=11;fontStyle=1;fontFamily=Helvetica;" edge="1">
          <mxGeometry relative="1" as="geometry">
