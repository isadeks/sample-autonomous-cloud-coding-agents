        <mxCell id="p2-d3" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=light-dark(#FFF3E0,#3a2a0e);strokeColor=#ED7100;strokeWidth=2;fontColor=#ED7100;fontSize=12;fontStyle=1;fontFamily=Helvetica;spacing=4;" value="Deny?" vertex="1">
