        <mxCell id="p2-e9" edge="1" parent="1" source="p2-d3" style="endArrow=classic;html=1;strokeColor=#8C4FFF;strokeWidth=2;fontColor=#8C4FFF;fontSize=11;fontStyle=1;fontFamily=Helvetica;jumpStyle=arc;jumpSize=12;" target="p2-collect">
          <mxGeometry relative="1" as="geometry" />
