            <mxPoint x="1970" y="1130" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="p11-m16-l" parent="1" style="text;html=1;align=center;fontSize=11;fontFamily=Helvetica;fontColor=#8C4FFF;fontStyle=1;" value="16: Bash(&quot;terraform init&quot;) — PreToolUse fires" vertex="1">
          <mxGeometry height="18" width="400" x="1800" y="1108" as="geometry" />
        </mxCell>
        <mxCell id="p11-m17" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=light-dark(#E8F5E9,#0f2f12);strokeColor=#2E7D32;strokeWidth=2;fontSize=11;fontFamily=Helvetica;fontColor=light-dark(#111111,#E0E0E0);align=left;spacing=8;" value="17: PolicyEngine FAST-PATH: hard-deny pass (no match) → check allowlist[&quot;all_session&quot;]==True → ALLOW (skip soft-deny eval entirely, ~0.5ms)" vertex="1">
          <mxGeometry height="60" width="900" x="1500" y="1160" as="geometry" />
        </mxCell>
        <mxCell id="p11-m18" parent="1" style="html=1;endArrow=classic;strokeColor=#555555;strokeWidth=2;fontColor=#555555;fontSize=11;fontStyle=1;fontFamily=Helvetica;" edge="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="2200" y="1250" as="sourcePoint" />
            <mxPoint x="2660" y="1250" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="p11-m18-l" parent="1" style="text;html=1;align=center;fontSize=11;fontFamily=Helvetica;fontColor=#555555;fontStyle=1;" value="18: terraform init / plan / apply (many Bash calls, all fast-path)" vertex="1">
          <mxGeometry height="18" width="500" x="2130" y="1228" as="geometry" />
        </mxCell>
        <mxCell id="p11-m19" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=light-dark(#F5F5F5,#1a1a1a);strokeColor=#555555;strokeWidth=1;fontSize=11;fontFamily=Helvetica;fontColor=light-dark(#111111,#E0E0E0);align=left;spacing=6;" value="19: ZERO approval gates fire during the entire task. User can be AFK. Task runs autonomously end-to-end." vertex="1">
          <mxGeometry height="40" width="1400" x="20" y="1290" as="geometry" />
        </mxCell>
        <mxCell id="p11-phase5" parent="1" style="text;html=1;align=left;fontSize=13;fontStyle=1;fontFamily=Helvetica;fontColor=#DD344C;" value="── Phase 5: Hard-deny still enforces (all_session is NOT superuser) ──" vertex="1">
          <mxGeometry height="20" width="600" x="60" y="1360" as="geometry" />
        </mxCell>
        <mxCell id="p11-m20" parent="1" style="html=1;endArrow=classic;strokeColor=#8C4FFF;strokeWidth=2;fontColor=#8C4FFF;fontSize=11;fontStyle=1;fontFamily=Helvetica;" edge="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="2200" y="1400" as="sourcePoint" />
            <mxPoint x="1970" y="1400" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="p11-m20-l" parent="1" style="text;html=1;align=center;fontSize=11;fontFamily=Helvetica;fontColor=#8C4FFF;fontStyle=1;" value="20: (hypothetical bad call) Bash(&quot;rm -rf /&quot;) — PreToolUse fires" vertex="1">
          <mxGeometry height="18" width="500" x="1700" y="1378" as="geometry" />
        </mxCell>
        <mxCell id="p11-m21" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=light-dark(#FFEBEE,#3a1518);strokeColor=#DD344C;strokeWidth=2;fontSize=11;fontFamily=Helvetica;fontColor=light-dark(#111111,#E0E0E0);align=left;spacing=8;" value="21: PolicyEngine: HARD-DENY runs FIRST (before allowlist check)&#10;    `rm_rf_root` rule matches → Decision.Deny — all_session does NOT bypass.&#10;    Return: DENY" vertex="1">
          <mxGeometry height="80" width="900" x="1500" y="1430" as="geometry" />
        </mxCell>
        <mxCell id="p11-m22" parent="1" style="html=1;endArrow=classic;strokeColor=#8C4FFF;strokeWidth=2;dashed=1;fontColor=#8C4FFF;fontSize=11;fontStyle=1;fontFamily=Helvetica;" edge="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1970" y="1540" as="sourcePoint" />
            <mxPoint x="2200" y="1540" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="p11-m22-l" parent="1" style="text;html=1;align=center;fontSize=11;fontFamily=Helvetica;fontColor=#8C4FFF;fontStyle=1;" value="22: return { permissionDecision: &quot;deny&quot; }" vertex="1">
          <mxGeometry height="18" width="400" x="1800" y="1518" as="geometry" />
        </mxCell>
        <mxCell id="p11-phase6" parent="1" style="text;html=1;align=left;fontSize=13;fontStyle=1;fontFamily=Helvetica;fontColor=#8C4FFF;" value="── Phase 6: Complete ──" vertex="1">
          <mxGeometry height="20" width="300" x="60" y="1570" as="geometry" />
        </mxCell>
        <mxCell id="p11-m23" parent="1" style="html=1;endArrow=classic;strokeColor=#555555;strokeWidth=2;fontColor=#555555;fontSize=11;fontStyle=1;fontFamily=Helvetica;" edge="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="2200" y="1610" as="sourcePoint" />
            <mxPoint x="2660" y="1610" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="p11-m23-l" parent="1" style="text;html=1;align=center;fontSize=11;fontFamily=Helvetica;fontColor=#555555;fontStyle=1;" value="23: agent opens PR with terraform output — task COMPLETED" vertex="1">
          <mxGeometry height="18" width="500" x="2100" y="1588" as="geometry" />
        </mxCell>
        <mxCell id="p11-whenuse" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=light-dark(#E3F2FD,#0d2638);strokeColor=#1F6FEB;strokeWidth=2;fontSize=12;fontFamily=Helvetica;fontColor=light-dark(#111111,#E0E0E0);align=left;verticalAlign=top;spacing=14;" value="&lt;b style=&quot;font-size:14px;color:#1F6FEB&quot;&gt;When to use --pre-approve all_session&lt;/b&gt;&#10;&#10;  • Scheduled automation (nightly runs)&#10;  • Pre-vetted tasks on trusted repos&#10;  • AI-DLC Phase 3 (fully-implemented design approved)&#10;  • Cron-triggered maintenance&#10;  • Orchestrator fire-and-forget path (no interactive stream)&#10;&#10;Trade-off: convenience vs. per-call oversight. Use only on repos&#10;where you trust the Blueprint + Cedar hard-deny set completely." vertex="1">
          <mxGeometry height="320" width="1020" x="60" y="1660" as="geometry" />
        </mxCell>
        <mxCell id="p11-safety" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=light-dark(#FFEBEE,#3a1518);strokeColor=#DD344C;strokeWidth=2;fontSize=12;fontFamily=Helvetica;fontColor=light-dark(#111111,#E0E0E0);align=left;verticalAlign=top;spacing=14;" value="&lt;b style=&quot;font-size:14px;color:#DD344C&quot;&gt;Safety layers that still enforce&lt;/b&gt;&#10;&#10;  • Hard-deny ALWAYS enforces — all_session is NOT superuser&#10;  • Blueprint.security.maxPreApprovalScope caps user requests&#10;  • CLI requires explicit --yes to skip the warning&#10;      (muscle-memory protection)&#10;  • TaskTable records initial_approvals for audit trail&#10;  • ProgressWriter emits &quot;pre_approvals_loaded&quot; milestone&#10;      so audit log shows the posture was granted at submit time" vertex="1">
          <mxGeometry height="320" width="1020" x="1120" y="1660" as="geometry" />
        </mxCell>
        <mxCell id="p11-rejectbox" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=light-dark(#FFF9C4,#3a2e10);strokeColor=#F9A825;strokeWidth=2;fontSize=11;fontFamily=Courier New;fontColor=light-dark(#111111,#E0E0E0);align=left;verticalAlign=top;spacing=14;" value="&lt;b style=&quot;font-family:Helvetica;color:#BF5700;font-size:13px&quot;&gt;What would happen WITHOUT the Blueprint allowing all_session&lt;/b&gt;&#10;&#10;&lt;span style=&quot;font-family:Helvetica&quot;&gt;If the repo's blueprint.yaml has `maxPreApprovalScope: &quot;tool_type_session&quot;` (or is absent, defaulting to the restrictive cap),&#10;the request for `all_session` would be rejected at Step 8:&lt;/span&gt;&#10;&#10;CreateTaskFn returns 400:&#10;&#10;  {&#10;    &quot;error&quot;: &quot;VALIDATION_ERROR&quot;,&#10;    &quot;message&quot;: &quot;all_session scope prohibited by repo Blueprint&quot;,&#10;    &quot;field&quot;: &quot;initial_approvals&quot;,&#10;    &quot;details&quot;: {&#10;      &quot;requested&quot;: &quot;all_session&quot;,&#10;      &quot;max_allowed&quot;: &quot;tool_type_session&quot;&#10;    }&#10;  }&#10;&#10;&lt;span style=&quot;font-family:Helvetica&quot;&gt;The task is never created. User must either narrow the scope or get admin to update the Blueprint.&lt;/span&gt;" vertex="1">
          <mxGeometry height="520" width="2080" x="60" y="2000" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
