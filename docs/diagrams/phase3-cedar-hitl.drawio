        <mxCell id="p4t-m6-l" parent="1" style="text;html=1;align=center;fontSize=11;fontFamily=Helvetica;fontColor=#2E7D32;" value="6: SSE event: approval timed out" vertex="1">
          <mxGeometry height="18" width="220" x="1130" y="1473" as="geometry" />
        </mxCell>
        <mxCell id="p4t-m7" edge="1" parent="1" style="html=1;endArrow=classic;strokeColor=#C925D1;strokeWidth=2;fontColor=#C925D1;fontSize=11;fontFamily=Helvetica;">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="350" y="1540" as="sourcePoint" />
            <mxPoint x="870" y="1540" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="p4t-m7-l" parent="1" style="text;html=1;align=center;fontSize=11;fontFamily=Helvetica;fontColor=#C925D1;" value="7: UpdateItem — task_status: AWAITING_APPROVAL → RUNNING" vertex="1">
          <mxGeometry height="18" width="460" x="400" y="1518" as="geometry" />
        </mxCell>
        <mxCell id="p4t-m8" edge="1" parent="1" style="html=1;endArrow=classic;strokeColor=#2E7D32;strokeWidth=2;dashed=1;fontColor=#2E7D32;fontSize=11;fontStyle=1;fontFamily=Helvetica;">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="350" y="1585" as="sourcePoint" />
            <mxPoint x="130" y="1585" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="p4t-m8-l" parent="1" style="text;html=1;align=left;fontSize=11;fontFamily=Helvetica;fontColor=#ED7100;fontStyle=1;" value="8: return { permissionDecision: &quot;deny&quot;, permissionDecisionReason: &quot;Approval timeout (no response in 600s)&quot; }" vertex="1">
          <mxGeometry height="18" width="640" x="150" y="1563" as="geometry" />
        </mxCell>
        <mxCell id="p4t-m9" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=light-dark(#FFEBEE,#3a1616);strokeColor=#DD344C;strokeWidth=1.5;fontSize=11;fontFamily=Helvetica;fontColor=#DD344C;fontStyle=1;align=center;verticalAlign=middle;spacing=6;" value="9: SDK does NOT execute. Fail-closed. Timeout reason enters agent context — agent may decide to skip this action or rephrase." vertex="1">
          <mxGeometry height="40" width="900" x="90" y="1615" as="geometry" />
        </mxCell>
        <mxCell id="p4-note" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=light-dark(#FFF9C4,#3a2e10);strokeColor=#F9A825;strokeWidth=1.5;fontSize=11;fontFamily=Helvetica;fontColor=light-dark(#BF5700,#FFD180);align=left;verticalAlign=top;spacing=10;" value="&lt;b&gt;Invariants across both branches&lt;/b&gt;&lt;br&gt;&lt;br&gt;· Tool is NEVER executed after soft-deny unless an explicit APPROVED decision is observed.&lt;br&gt;· Task always transitions AWAITING_APPROVAL → RUNNING after the hook exits its poll, regardless of outcome.&lt;br&gt;· Both paths emit progress events so the watcher sees a terminal status.&lt;br&gt;· Conditional UpdateItem from DenyTaskFn/timeout path fails closed — if an approve/deny race both try to transition from PENDING, only the first wins; the loser gets a 409 / ConditionalCheckFailed.&lt;br&gt;· Approval row stays in DDB until TTL (1h); CLI can read final status later." vertex="1">
          <mxGeometry height="240" width="900" x="1760" y="300" as="geometry" />
        </mxCell>
        <mxCell id="p4-timeline" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=light-dark(#FFFFFF,#1a1a1a);strokeColor=#8C4FFF;strokeWidth=2;fontSize=11;fontFamily=Helvetica;fontColor=#8C4FFF;align=left;verticalAlign=top;spacing=10;" value="&lt;b style=&quot;font-size:13px&quot;&gt;Timeout resolution&lt;/b&gt;&lt;br&gt;&lt;br&gt;timeout_s = min(&lt;br&gt;  per-rule @approval_timeout_s,&lt;br&gt;  task blueprint default,&lt;br&gt;  600s fallback&lt;br&gt;)&lt;br&gt;&lt;br&gt;If multiple rules match (page 2), the MINIMUM timeout wins — fail-faster semantics ensure a dangerous compound rule doesn't inherit a lax deadline from one of its matches." vertex="1">
          <mxGeometry height="250" width="440" x="1760" y="1200" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
