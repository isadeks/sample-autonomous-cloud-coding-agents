        <mxCell id="p2-s3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=light-dark(#EDE7F6,#1a1530);strokeColor=#8C4FFF;strokeWidth=2;fontColor=#8C4FFF;fontSize=12;fontStyle=1;fontFamily=Helvetica;spacing=8;spacingLeft=10;spacingRight=10;" value="Step 3 — SOFT_DENY eval&#10;&lt;span style=&quot;font-size:10px;font-weight:normal&quot;&gt;Cedar.is_authorized(&#10;  SOFT_DENY_POLICIES, req)&lt;/span&gt;" vertex="1">
