        <mxCell id="p2-e6-lbl" parent="1" style="text;html=1;align=center;fontSize=11;fontFamily=Helvetica;fontColor=#2E7D32;fontStyle=1;" value="Yes" vertex="1">
          <mxGeometry height="18" width="40" x="310" y="742" as="geometry" />
