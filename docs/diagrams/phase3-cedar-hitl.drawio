        <mxCell id="p12-s5-1" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=light-dark(#FFFFFF,#1a1a1a);strokeColor=#8C4FFF;strokeWidth=1;fontSize=11;fontFamily=Courier New;fontColor=light-dark(#111111,#E0E0E0);align=left;verticalAlign=middle;spacing=10;" value="all_session" vertex="1">
          <mxGeometry height="80" width="220" x="2280" y="560" as="geometry" />
