        <mxCell id="p4t-m4-l" parent="1" style="text;html=1;align=center;fontSize=11;fontFamily=Helvetica;fontColor=#ED7100;fontStyle=1;" value="4: conditional UpdateItem — status: PENDING → TIMED_OUT (decided_at=now)" vertex="1">
