        <mxCell id="ta-n" parent="ta" style="text;html=1;fontSize=10;fontFamily=Helvetica;fontColor=#8C4FFF;align=left;verticalAlign=top;spacing=4;whiteSpace=wrap;" value="&lt;b&gt;Keys:&lt;/b&gt; PK=task_id, SK=request_id (ULID)&#10;&lt;b&gt;TTL:&lt;/b&gt; 1h from created_at&#10;&lt;b&gt;KMS + PITR&lt;/b&gt; (same as Task tables)&#10;&#10;&lt;b&gt;Attributes:&lt;/b&gt;&#10;  tool_name, tool_input_preview,&#10;  reason, severity, category,&#10;  matching_rule_ids[], timeout_s,&#10;  status (PENDING|APPROVED|DENIED|TIMED_OUT),&#10;  scope (when APPROVED),&#10;  decided_at, decided_by,&#10;  created_at, ttl&#10;&#10;&lt;b&gt;Writers:&lt;/b&gt; PolicyEngine (PutItem),&#10;             ApproveTaskFn / DenyTaskFn (UpdateItem)&#10;&lt;b&gt;Readers:&lt;/b&gt; PolicyEngine (poll 2s→5s)" vertex="1">
          <mxGeometry height="210" width="280" x="70" y="34" as="geometry" />
        </mxCell>
        <mxCell id="rtjwt" parent="cloud" style="rounded=1;fillColor=light-dark(#E0F2F1,#E0F2F1);strokeColor=#01A88D;strokeWidth=1.5;html=1;verticalAlign=top;fontStyle=1;fontSize=12;fontColor=#01A88D;fontFamily=Helvetica;container=1;collapsible=0;spacingLeft=6;spacingTop=4;" value="AgentCore Runtime-JWT / Runtime-IAM MicroVM" vertex="1">
