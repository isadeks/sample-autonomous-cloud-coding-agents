            <mxPoint x="570" y="1370" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="p3-m23-l" parent="1" style="text;html=1;align=center;fontSize=11;fontFamily=Helvetica;fontColor=#8C4FFF;fontStyle=1;" value="21: evaluate_tool_use" vertex="1">
          <mxGeometry height="18" width="200" x="360" y="1348" as="geometry" />
        </mxCell>
        <mxCell id="p3-m24" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=light-dark(#E3F2FD,#0d2638);strokeColor=#1F6FEB;strokeWidth=1.5;fontSize=11;fontFamily=Helvetica;fontColor=#1F6FEB;align=left;verticalAlign=top;spacing=6;" value="22: HARD_DENY eval → no match. Allowlist fast-path: tool_type=Bash ∈ allowlist → ALLOW immediately (skip SOFT eval).&#10;No new approval request written. No state transition." vertex="1">
          <mxGeometry height="60" width="520" x="580" y="1390" as="geometry" />
        </mxCell>
        <mxCell id="p3-m25" edge="1" parent="1" style="html=1;endArrow=classic;strokeColor=#2E7D32;strokeWidth=2;dashed=1;fontColor=#2E7D32;fontSize=11;fontStyle=1;fontFamily=Helvetica;">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="350" y="1470" as="sourcePoint" />
            <mxPoint x="130" y="1470" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="p3-m25-l" parent="1" style="text;html=1;align=center;fontSize=11;fontFamily=Helvetica;fontColor=#2E7D32;fontStyle=1;" value="23: { permissionDecision: &quot;allow&quot; } (fast-path, no prompt)" vertex="1">
          <mxGeometry height="18" width="340" x="150" y="1448" as="geometry" />
        </mxCell>
        <mxCell id="p3-note" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=light-dark(#FFF9C4,#3a2e10);strokeColor=#F9A825;strokeWidth=1.5;fontSize=11;fontFamily=Helvetica;fontColor=light-dark(#BF5700,#FFD180);align=left;verticalAlign=top;spacing=10;" value="&lt;b&gt;Key design points&lt;/b&gt;&lt;br&gt;&lt;br&gt;1. Hook fabricates request_id client-side (ULID) to avoid extra round-trips.&lt;br&gt;2. Task transitions to AWAITING_APPROVAL but &lt;b&gt;holds its concurrency slot&lt;/b&gt; — a user who approves 5 minutes later doesn't lose their task.&lt;br&gt;3. Poll cadence is 2s for the first 30s (fast feedback), then 5s to reduce DDB RCUs.&lt;br&gt;4. ProgressWriter + SSEAdapter are the same channels Phase 1b/2 use; Terminal A simply renders a new event type.&lt;br&gt;5. Allowlist is in-process (per container) — lost on restart. Phase 3 accepts this trade-off; attach-don't-spawn makes restarts rare (see page 6)." vertex="1">
          <mxGeometry height="230" width="740" x="36" y="1535" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
