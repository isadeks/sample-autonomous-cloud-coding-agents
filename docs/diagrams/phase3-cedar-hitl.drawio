        <mxCell id="p2-e3-lbl" parent="1" style="text;html=1;align=center;fontSize=11;fontFamily=Helvetica;fontColor=#DD344C;fontStyle=1;" value="Yes" vertex="1">
          <mxGeometry height="18" width="40" x="310" y="452" as="geometry" />
        </mxCell>
        <mxCell id="p2-e4" edge="1" parent="1" source="p2-d1" style="endArrow=classic;html=1;strokeColor=#2E7D32;strokeWidth=2;fontColor=#2E7D32;fontSize=11;fontStyle=1;fontFamily=Helvetica;jumpStyle=arc;jumpSize=12;" target="p2-s2">
