        <mxCell id="p5-m12-box" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=light-dark(#EDE7F6,#1a1530);strokeColor=#8C4FFF;strokeWidth=2;fontSize=10;fontFamily=Helvetica;fontColor=#8C4FFF;align=left;verticalAlign=top;spacing=8;" value="&lt;b&gt;11: PolicyEngine.__init__(initial_approvals=[...])&lt;/b&gt;&#10;&#10;for scope in initial_approvals:&#10;    self._allowlist.add(scope)&#10;&#10;# Seeded BEFORE first tool call. Fast-path hits immediately." vertex="1">
