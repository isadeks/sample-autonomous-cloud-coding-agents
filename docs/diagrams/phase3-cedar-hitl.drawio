          </mxGeometry>
        </mxCell>
        <mxCell id="p6-t4-m1-l" parent="1" style="text;html=1;align=center;fontSize=11;fontFamily=Helvetica;fontColor=#8C4FFF;" value="14: Write(infrastructure/terraform.tf) → REQUIRE_APPROVAL" vertex="1">
          <mxGeometry height="18" width="400" x="150" y="1008" as="geometry" />
        </mxCell>
        <mxCell id="p6-t4-m2-box" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=light-dark(#EDE7F6,#1a1530);strokeColor=#8C4FFF;strokeWidth=1.5;fontSize=11;fontFamily=Helvetica;fontColor=#8C4FFF;align=left;verticalAlign=middle;spacing=8;" value="15: Allowlist fast-path: tool_type=Write NOT in allowlist, no bash_pattern match, no rule match.&#10;    SOFT_DENY eval → rule &quot;write_infra_files&quot; matches → REQUIRE_APPROVAL." vertex="1">
          <mxGeometry height="60" width="560" x="460" y="1055" as="geometry" />
        </mxCell>
        <mxCell id="p6-t4-m3" edge="1" parent="1" style="html=1;endArrow=classic;strokeColor=#8C4FFF;strokeWidth=2;fontColor=#8C4FFF;fontSize=11;fontStyle=1;fontFamily=Helvetica;">
          <mxGeometry relative="1" as="geometry">
