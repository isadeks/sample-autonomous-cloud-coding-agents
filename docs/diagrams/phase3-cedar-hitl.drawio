        <mxCell id="p6-t4-hdr" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=light-dark(#EDE7F6,#1a1530);strokeColor=#8C4FFF;strokeWidth=2;fontSize=13;fontStyle=1;fontFamily=Helvetica;fontColor=#8C4FFF;align=left;verticalAlign=middle;spacing=8;spacingLeft=12;" value="TURN 4 — Agent: Write(&quot;infrastructure/terraform.tf&quot;) → different rule write_infra_files → REQUIRE_APPROVAL" vertex="1">
          <mxGeometry height="32" width="1400" x="90" y="970" as="geometry" />
        </mxCell>
        <mxCell id="p6-t4-m1" edge="1" parent="1" style="html=1;endArrow=classic;strokeColor=#8C4FFF;strokeWidth=2;fontColor=#8C4FFF;fontSize=11;fontFamily=Helvetica;">
          <mxGeometry relative="1" as="geometry">
