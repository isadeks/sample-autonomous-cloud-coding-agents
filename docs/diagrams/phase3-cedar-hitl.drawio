        </mxCell>
        <mxCell id="p2-e6" edge="1" parent="1" source="p2-d2" style="endArrow=classic;html=1;strokeColor=#2E7D32;strokeWidth=2;fontColor=#2E7D32;fontSize=11;fontStyle=1;fontFamily=Helvetica;jumpStyle=arc;jumpSize=12;" target="p2-allow1">
          <mxGeometry relative="1" as="geometry" />
