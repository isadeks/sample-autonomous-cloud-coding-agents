        <mxCell id="p4t-tick" parent="1" style="text;html=1;align=left;verticalAlign=middle;fontSize=11;fontFamily=Helvetica;fontColor=#ED7100;fontStyle=2;" value="... 600s elapses — no human decision ..." vertex="1">
