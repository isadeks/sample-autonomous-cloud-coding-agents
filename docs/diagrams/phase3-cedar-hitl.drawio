        <mxCell id="p9-t" parent="1" style="text;html=1;align=left;verticalAlign=top;fontSize=28;fontStyle=1;fontFamily=Helvetica;fontColor=#8C4FFF;" value="End-to-end scenario A — force-push with per-rule timeout (§14.1)" vertex="1">
          <mxGeometry height="35" width="3500" x="40" y="25" as="geometry" />
        </mxCell>
        <mxCell id="p9-sub" parent="1" style="text;html=1;align=left;verticalAlign=top;fontSize=13;fontFamily=Helvetica;fontColor=#555555;" value="Full story: `bgagent run ... --approval-timeout 300` → container starts → agent attempts `git push --force origin main` → two soft-deny rules match (force_push_any 300s/medium, force_push_main 600s/high) → annotation merge (min timeout, max severity) → approval gate → user approves with `--scope tool_type:Bash` from Terminal B → allowlist updated → force-push executes → subsequent `git status` auto-passes via allowlist fast-path → task completes." vertex="1">
          <mxGeometry height="60" width="3500" x="40" y="62" as="geometry" />
        </mxCell>
