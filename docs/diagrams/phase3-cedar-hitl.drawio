        <mxCell id="p4t-m3" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=light-dark(#FFF3E0,#3a2a0e);strokeColor=#ED7100;strokeWidth=1.5;fontSize=11;fontFamily=Helvetica;fontColor=#ED7100;fontStyle=1;align=left;verticalAlign=middle;spacing=6;" value="3: elapsed ≥ timeout_s → exit loop" vertex="1">
          <mxGeometry height="30" width="320" x="360" y="1360" as="geometry" />
        </mxCell>
        <mxCell id="p4t-m4" edge="1" parent="1" style="html=1;endArrow=classic;strokeColor=#ED7100;strokeWidth=2;fontColor=#ED7100;fontSize=11;fontStyle=1;fontFamily=Helvetica;">
          <mxGeometry relative="1" as="geometry">
