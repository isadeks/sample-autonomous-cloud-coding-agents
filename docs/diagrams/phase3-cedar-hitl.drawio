        <mxCell id="p12-s5-2" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=light-dark(#FFFFFF,#1a1a1a);strokeColor=#8C4FFF;strokeWidth=1;fontSize=11;fontFamily=Courier New;fontColor=light-dark(#111111,#E0E0E0);align=left;verticalAlign=middle;spacing=10;" value="all_session" vertex="1">
          <mxGeometry height="80" width="260" x="2500" y="560" as="geometry" />
        </mxCell>
        <mxCell id="p12-s5-3" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=light-dark(#FFFFFF,#1a1a1a);strokeColor=#8C4FFF;strokeWidth=1;fontSize=11;fontFamily=Helvetica;fontColor=light-dark(#111111,#E0E0E0);align=left;verticalAlign=middle;spacing=10;" value="All soft-deny auto-pass (hard-deny STILL enforces). Subject to Blueprint maxPreApprovalScope." vertex="1">
          <mxGeometry height="80" width="340" x="2760" y="560" as="geometry" />
        </mxCell>
        <mxCell id="p12-s5-4" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=light-dark(#FFFFFF,#1a1a1a);strokeColor=#8C4FFF;strokeWidth=1;fontSize=11;fontFamily=Helvetica;fontColor=light-dark(#111111,#E0E0E0);align=left;verticalAlign=middle;spacing=10;" value="Submit + mid-task" vertex="1">
          <mxGeometry height="80" width="240" x="3100" y="560" as="geometry" />
        </mxCell>
        <mxCell id="p12-scope-note" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=light-dark(#FFF9C4,#3a2e10);strokeColor=#F9A825;strokeWidth=2;fontSize=11;fontFamily=Helvetica;fontColor=light-dark(#111111,#E0E0E0);align=left;verticalAlign=top;spacing=14;" value="&lt;b style=&quot;color:#BF5700&quot;&gt;Scope rank ordering (for Blueprint cap check)&lt;/b&gt;&#10;&#10;rank(this_call) = 0&#10;rank(rule:X) = 1&#10;rank(bash_pattern:X) = 2&#10;rank(tool_type:X) = 3&#10;rank(all_session) = 4&#10;&#10;CreateTaskFn rejects at submit if rank(requested) &gt; rank(blueprint.maxPreApprovalScope)." vertex="1">
          <mxGeometry height="240" width="1060" x="2280" y="660" as="geometry" />
        </mxCell>
        <mxCell id="p12-rest-h" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=light-dark(#EDE7F6,#1a1530);strokeColor=#8C4FFF;strokeWidth=2;fontSize=16;fontStyle=1;fontFamily=Helvetica;fontColor=#8C4FFF;align=left;verticalAlign=middle;spacing=14;" value="Bottom band — REST endpoints quick reference" vertex="1">
          <mxGeometry height="50" width="3280" x="60" y="940" as="geometry" />
        </mxCell>
        <mxCell id="p12-e1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=light-dark(#FFFFFF,#1a1a1a);strokeColor=#8C4FFF;strokeWidth=2;fontSize=12;fontFamily=Helvetica;fontColor=light-dark(#111111,#E0E0E0);align=left;verticalAlign=top;spacing=14;" value="&lt;b style=&quot;color:#8C4FFF;font-size:13px&quot;&gt;POST /v1/tasks&lt;/b&gt; &lt;span style=&quot;color:#999&quot;&gt;(extended for Phase 3)&lt;/span&gt;&#10;&#10;&lt;span style=&quot;font-family:Courier New&quot;&gt;Request body:&#10;{&#10;  repo: &quot;org/name&quot;,&#10;  task: &quot;description&quot;,&#10;  task_type: &quot;new_task&quot; | ...,&#10;  approval_timeout_s: 300,       // NEW&#10;  initial_approvals: [&quot;...&quot;]     // NEW (≤20, each ≤128 chars)&#10;}&lt;/span&gt;&#10;&#10;&lt;b&gt;Validation&lt;/b&gt;: timeout ≤ 3600; scope syntax; Blueprint.maxPreApprovalScope cap.&#10;&#10;&lt;b&gt;Returns&lt;/b&gt;: 201 { task_id } or 400 VALIDATION_ERROR." vertex="1">
          <mxGeometry height="440" width="1060" x="60" y="1010" as="geometry" />
        </mxCell>
        <mxCell id="p12-e2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=light-dark(#FAFAFA,#222222);strokeColor=#8C4FFF;strokeWidth=2;fontSize=12;fontFamily=Helvetica;fontColor=light-dark(#111111,#E0E0E0);align=left;verticalAlign=top;spacing=14;" value="&lt;b style=&quot;color:#8C4FFF;font-size:13px&quot;&gt;POST /v1/tasks/{id}/approve&lt;/b&gt; &lt;span style=&quot;color:#999&quot;&gt;(NEW)&lt;/span&gt;&#10;&#10;&lt;span style=&quot;font-family:Courier New&quot;&gt;Request body:&#10;{&#10;  request_id: &quot;01KPR...&quot;,&#10;  decision: &quot;approve&quot;,&#10;  scope: &quot;tool_type:Bash&quot;     // optional (default: this_call)&#10;}&lt;/span&gt;&#10;&#10;&lt;b&gt;Auth&lt;/b&gt;: Cognito JWT; must match TaskTable.user_id.&#10;&lt;b&gt;Validation&lt;/b&gt;: scope syntax; scope ≤128 chars; rank ≤ Blueprint cap.&#10;&lt;b&gt;Concurrency&lt;/b&gt;: conditional UpdateItem PENDING→APPROVED.&#10;&#10;&lt;b&gt;Returns&lt;/b&gt;: 200, 404 (unknown request_id), 409 (already decided), 410 (timed out)." vertex="1">
          <mxGeometry height="440" width="1060" x="1160" y="1010" as="geometry" />
        </mxCell>
        <mxCell id="p12-e3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=light-dark(#FFFFFF,#1a1a1a);strokeColor=#8C4FFF;strokeWidth=2;fontSize=12;fontFamily=Helvetica;fontColor=light-dark(#111111,#E0E0E0);align=left;verticalAlign=top;spacing=14;" value="&lt;b style=&quot;color:#8C4FFF;font-size:13px&quot;&gt;POST /v1/tasks/{id}/deny&lt;/b&gt; &lt;span style=&quot;color:#999&quot;&gt;(NEW)&lt;/span&gt;&#10;&#10;&lt;span style=&quot;font-family:Courier New&quot;&gt;Request body:&#10;{&#10;  request_id: &quot;01KPR...&quot;,&#10;  reason: &quot;too risky&quot;        // optional, ≤512 chars&#10;}&lt;/span&gt;&#10;&#10;&lt;b&gt;Auth&lt;/b&gt;: Cognito JWT; must match TaskTable.user_id.&#10;&lt;b&gt;Concurrency&lt;/b&gt;: conditional UpdateItem PENDING→DENIED.&#10;&#10;&lt;b&gt;Effect&lt;/b&gt;: hook's next poll reads DENIED → returns deny to SDK.&#10;         Task returns to RUNNING (agent may adapt) or fails.&#10;&#10;&lt;b&gt;Returns&lt;/b&gt;: 200, 404, 409, 410." vertex="1">
          <mxGeometry height="440" width="1060" x="2280" y="1010" as="geometry" />
        </mxCell>
        <mxCell id="p12-footer" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=light-dark(#FAFAFA,#222222);strokeColor=#999999;strokeWidth=1;fontSize=11;fontFamily=Helvetica;fontColor=#666666;align=center;verticalAlign=middle;spacing=14;" value="Details: &lt;b&gt;docs/design/PHASE3_CEDAR_HITL.md&lt;/b&gt;  ·  Companion: &lt;b&gt;docs/diagrams/interactive-agents-phases.drawio&lt;/b&gt; (current state, all shipped phases)" vertex="1">
          <mxGeometry height="50" width="3280" x="60" y="1480" as="geometry" />
        </mxCell>
      </root>
