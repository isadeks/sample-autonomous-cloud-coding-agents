        <mxCell id="note" parent="cloud" style="rounded=1;fillColor=light-dark(#FFF9C4,#3a2e10);strokeColor=#F9A825;strokeWidth=1.5;html=1;align=left;verticalAlign=top;fontSize=11;fontStyle=0;fontFamily=Helvetica;fontColor=light-dark(#BF5700,#FFD180);spacing=10;whiteSpace=wrap;" value="&lt;b&gt;Phase 3 summary — 5 NEW resources:&lt;/b&gt;&lt;br&gt;1. TaskApprovalsTable (DDB)&lt;br&gt;2. ApproveTaskFn (Lambda) + POST /tasks/{id}/approve&lt;br&gt;3. DenyTaskFn (Lambda) + POST /tasks/{id}/deny&lt;br&gt;4. initial_approvals column on TaskTable&lt;br&gt;5. PolicyEngine split into HARD + SOFT + in-process allowlist&lt;br&gt;&lt;br&gt;&lt;b&gt;AWAITING_APPROVAL&lt;/b&gt; is a new task state (holds concurrency slot)." vertex="1">
          <mxGeometry height="210" width="420" x="1750" y="160" as="geometry" />
        </mxCell>
