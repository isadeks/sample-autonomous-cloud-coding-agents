        <mxCell id="p11-m14" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=light-dark(#E8F5E9,#0f2f12);strokeColor=#2E7D32;strokeWidth=2;fontSize=11;fontFamily=Helvetica;fontColor=light-dark(#111111,#E0E0E0);align=left;spacing=8;" value="14: PolicyEngine.__init__ seeds allowlist: _allowlist[&quot;all_session&quot;] = True&#10;    Hard-deny policy pack is still loaded (always). Soft-deny pack loaded but will be SKIPPED due to all_session fast-path." vertex="1">
          <mxGeometry height="80" width="1100" x="1500" y="960" as="geometry" />
