        <mxCell id="p2-req" parent="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=light-dark(#EDE7F6,#1a1530);strokeColor=#8C4FFF;strokeWidth=3;fontColor=#8C4FFF;fontSize=13;fontStyle=1;fontFamily=Helvetica;spacing=6;" value="REQUIRE_APPROVAL&#10;&lt;span style=&quot;font-size:9px;font-weight:normal&quot;&gt;{reason, timeout_s, severity,&#10;  matching_rule_ids, category}&lt;br&gt;→ hook asks human&lt;/span&gt;" vertex="1">
          <mxGeometry height="110" width="260" x="720" y="985" as="geometry" />
        </mxCell>
        <mxCell id="p2-s4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=light-dark(#E8F5E9,#123318);strokeColor=#2E7D32;strokeWidth=2;fontColor=#2E7D32;fontSize=12;fontStyle=1;fontFamily=Helvetica;spacing=8;" value="Step 4 — Default" vertex="1">
          <mxGeometry height="70" width="260" x="90" y="1170" as="geometry" />
        </mxCell>
        <mxCell id="p2-allow2" parent="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=light-dark(#E8F5E9,#123318);strokeColor=#2E7D32;strokeWidth=3;fontColor=#2E7D32;fontSize=13;fontStyle=1;fontFamily=Helvetica;spacing=6;" value="ALLOW&#10;(default-allow)" vertex="1">
          <mxGeometry height="80" width="180" x="130" y="1280" as="geometry" />
        </mxCell>
        <mxCell id="p2-e1" edge="1" parent="1" source="p2-start" style="endArrow=classic;html=1;strokeColor=#555555;strokeWidth=2;jumpStyle=arc;jumpSize=12;" target="p2-s1">
