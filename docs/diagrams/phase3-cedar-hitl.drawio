        <mxCell id="p11-warnbox" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=light-dark(#FFF9C4,#3a2e10);strokeColor=#F9A825;strokeWidth=2;fontSize=10;fontFamily=Courier New;fontColor=light-dark(#111111,#FFD180);align=left;verticalAlign=top;spacing=10;" value="Without --yes, CLI prints:&#10;&#10;WARNING: --pre-approve all_session disables all approval gates for this task.&#10;         The agent will run tools autonomously without any confirmation,&#10;         subject only to hard-deny policies (rm -rf /, write to .git/, etc).&#10;         Add --yes to skip this prompt.&#10;Continue? [y/N]" vertex="1">
