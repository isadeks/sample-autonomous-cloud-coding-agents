        </mxCell>
        <mxCell id="p2-e10" edge="1" parent="1" source="p2-collect" style="endArrow=classic;html=1;strokeColor=#8C4FFF;strokeWidth=2;jumpStyle=arc;jumpSize=12;" target="p2-req">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p2-e11" edge="1" parent="1" source="p2-d3" style="endArrow=classic;html=1;strokeColor=#2E7D32;strokeWidth=2;fontColor=#2E7D32;fontSize=11;fontStyle=1;fontFamily=Helvetica;jumpStyle=arc;jumpSize=12;" target="p2-s4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p2-e11-lbl" parent="1" style="text;html=1;align=center;fontSize=11;fontFamily=Helvetica;fontColor=#2E7D32;fontStyle=1;" value="No" vertex="1">
          <mxGeometry height="18" width="40" x="200" y="1112" as="geometry" />
        </mxCell>
        <mxCell id="p2-e12" edge="1" parent="1" source="p2-s4" style="endArrow=classic;html=1;strokeColor=#555555;strokeWidth=2;jumpStyle=arc;jumpSize=12;" target="p2-allow2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p2-inset" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=light-dark(#FFFFFF,#1a1a1a);strokeColor=#8C4FFF;strokeWidth=2;fontColor=#8C4FFF;fontSize=12;fontStyle=0;fontFamily=Helvetica;align=left;verticalAlign=top;spacing=10;" value="&lt;b style=&quot;font-size:14px&quot;&gt;Annotation resolution (multi-match merge)&lt;/b&gt;&lt;br&gt;&lt;br&gt;Cedar diagnostics.reasons returns a list of matching policy IDs. Each policy carries annotations (readable via policies_to_json_str):&lt;br&gt;&lt;br&gt;&lt;b&gt;@rule_id(&quot;stable-name&quot;)&lt;/b&gt; — stable identifier for scope grants (e.g. rule:force_push)&lt;br&gt;&lt;b&gt;@tier(&quot;hard&quot;|&quot;soft&quot;)&lt;/b&gt; — selects which policy set&lt;br&gt;&lt;b&gt;@approval_timeout_s(&quot;N&quot;)&lt;/b&gt; — per-rule override; default 600s&lt;br&gt;&lt;b&gt;@severity(&quot;low&quot;|&quot;medium&quot;|&quot;high&quot;)&lt;/b&gt; — UI + logging&lt;br&gt;&lt;b&gt;@category(&quot;destructive&quot;|&quot;network&quot;|&quot;filesystem&quot;|&quot;auth&quot;)&lt;/b&gt; — grouping&lt;br&gt;&lt;br&gt;&lt;b&gt;Merge rules when ≥2 rules match:&lt;/b&gt;&lt;br&gt;  · timeout_s: &lt;b&gt;min&lt;/b&gt; (fail-faster wins)&lt;br&gt;  · severity: &lt;b&gt;max&lt;/b&gt; (low &lt; medium &lt; high)&lt;br&gt;  · category: join with commas (no merge)&lt;br&gt;  · matching_rule_ids: union (all grants allowed)&lt;br&gt;&lt;br&gt;&lt;b&gt;Notes:&lt;/b&gt;&lt;br&gt;  · Cedar `like` is glob-only — `*` and `?`. No regex.&lt;br&gt;  · Missing annotations fall back to per-task defaults.&lt;br&gt;  · Hard-tier policies are NEVER subject to approval; they short-circuit at step 1." vertex="1">
          <mxGeometry height="620" width="620" x="1050" y="180" as="geometry" />
        </mxCell>
        <mxCell id="p2-code" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=light-dark(#F5F5F5,#1a1a1a);strokeColor=#666666;strokeWidth=1;fontColor=light-dark(#111111,#E0E0E0);fontSize=11;fontFamily=Courier New;align=left;verticalAlign=top;spacing=10;" value="&lt;b style=&quot;font-family:Helvetica;color:#8C4FFF&quot;&gt;Example SOFT policy&lt;/b&gt;&lt;br&gt;&lt;br&gt;@rule_id(&quot;force_push&quot;)&lt;br&gt;@tier(&quot;soft&quot;)&lt;br&gt;@severity(&quot;high&quot;)&lt;br&gt;@category(&quot;destructive&quot;)&lt;br&gt;@approval_timeout_s(&quot;600&quot;)&lt;br&gt;forbid (&lt;br&gt;&amp;nbsp;&amp;nbsp;principal,&lt;br&gt;&amp;nbsp;&amp;nbsp;action == Agent::Action::&quot;execute_bash&quot;,&lt;br&gt;&amp;nbsp;&amp;nbsp;resource&lt;br&gt;) when {&lt;br&gt;&amp;nbsp;&amp;nbsp;context.command like &quot;*git push --force*&quot;&lt;br&gt;};" vertex="1">
          <mxGeometry height="290" width="420" x="20" y="140" as="geometry" />
        </mxCell>
        <mxCell id="p2-types" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=light-dark(#FFFFFF,#1a1a1a);strokeColor=#1F6FEB;strokeWidth=2;fontColor=#1F6FEB;fontSize=11;fontStyle=0;fontFamily=Helvetica;align=left;verticalAlign=top;spacing=10;" value="&lt;b style=&quot;font-size:13px&quot;&gt;Allowlist scope vocabulary&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;this_call&lt;/b&gt; — one-shot, allowlist unchanged&lt;br&gt;&lt;b&gt;tool_type:&lt;X&gt;&lt;/b&gt; — all future Bash / Write / etc.&lt;br&gt;&lt;b&gt;bash_pattern:&lt;P&gt;&lt;/b&gt; — glob-matched bash cmds&lt;br&gt;&lt;b&gt;rule:&lt;RULE_ID&gt;&lt;/b&gt; — all tools matching this rule&lt;br&gt;&lt;b&gt;all_session&lt;/b&gt; — disable soft-deny for session&lt;br&gt;&lt;br&gt;Fast-path check order: rule → tool_type →&lt;br&gt;bash_pattern → all_session" vertex="1">
          <mxGeometry height="300" width="420" x="1750" y="495" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram name="3. Happy path — REQUIRE_APPROVAL" id="p3p3">
    <mxGraphModel dx="1692" dy="858" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="3200" pageHeight="2100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="p3-t" parent="1" style="text;html=1;align=left;verticalAlign=top;fontSize=28;fontStyle=1;fontFamily=Helvetica;fontColor=#8C4FFF;" value="PreToolUse hook — happy path REQUIRE_APPROVAL branch (approve + scope escalation)" vertex="1">
          <mxGeometry height="35" width="3100" x="40" y="25" as="geometry" />
        </mxCell>
        <mxCell id="p3-sub" parent="1" style="text;html=1;align=left;verticalAlign=top;fontSize=13;fontFamily=Helvetica;fontColor=#555555;" value="Tool call hits a soft-deny rule. Hook writes an approval request to TaskApprovalsTable, transitions task to AWAITING_APPROVAL, polls for a decision. User approves with --scope tool_type:Bash. Allowlist is updated. A later Bash call hits the fast-path with no new prompt." vertex="1">
          <mxGeometry height="40" width="3100" x="40" y="62" as="geometry" />
        </mxCell>
        <mxCell id="p3-bar" parent="1" style="line;strokeWidth=2;strokeColor=#8C4FFF;html=1;" value="" vertex="1">
          <mxGeometry height="10" width="3100" x="40" y="105" as="geometry" />
        </mxCell>
        <mxCell id="p3-a1" parent="1" style="shape=umlActor;verticalLabelPosition=bottom;labelBackgroundColor=none;verticalAlign=top;html=1;outlineConnect=0;fontColor=#2E7D32;fontSize=11;fontStyle=1;fontFamily=Helvetica;" value="SDK" vertex="1">
          <mxGeometry height="50" width="30" x="115" y="145" as="geometry" />
        </mxCell>
        <mxCell id="p3-a2" parent="1" style="shape=umlActor;verticalLabelPosition=bottom;labelBackgroundColor=none;verticalAlign=top;html=1;outlineConnect=0;fontColor=#8C4FFF;fontSize=11;fontStyle=1;fontFamily=Helvetica;" value="PreToolUse Hook" vertex="1">
