        <mxCell id="p12-actors" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=light-dark(#FFFFFF,#1a1a1a);strokeColor=#666666;strokeWidth=1;fontSize=12;fontFamily=Helvetica;fontColor=light-dark(#111111,#E0E0E0);align=left;verticalAlign=top;spacing=14;" value="&lt;b style=&quot;font-size:13px&quot;&gt;Actor colors (sequence diagrams)&lt;/b&gt;&#10;&#10;&lt;span style=&quot;color:#555555;font-weight:bold&quot;&gt;■&lt;/span&gt; Gray       = User / external / Bedrock / git&#10;&lt;span style=&quot;color:#2E7D32;font-weight:bold&quot;&gt;■&lt;/span&gt; Green      = CLI / SDK / SSE adapter&#10;&lt;span style=&quot;color:#DD344C;font-weight:bold&quot;&gt;■&lt;/span&gt; Red        = API Gateway (Cognito) / Cedar engine&#10;&lt;span style=&quot;color:#ED7100;font-weight:bold&quot;&gt;■&lt;/span&gt; Orange     = Lambda functions / ProgressWriter&#10;&lt;span style=&quot;color:#C925D1;font-weight:bold&quot;&gt;■&lt;/span&gt; Magenta    = DynamoDB tables (TaskTable, TaskEventsTable)&#10;&lt;span style=&quot;color:#8C4FFF;font-weight:bold&quot;&gt;■&lt;/span&gt; Purple     = Phase 3 NEW (hook, PolicyEngine, TaskApprovalsTable, ApproveTaskFn, Runtime-*)" vertex="1">
