        <mxCell id="gh-repost-label" parent="1" style="text;html=1;align=center;fontSize=11;strokeColor=none;fillColor=#FFFFFF;fontFamily=Courier New" value="POST /issues/{n}/comments (re-create)  →  log fanout.github.recreated" vertex="1">
