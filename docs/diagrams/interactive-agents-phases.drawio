        <mxCell id="f-gd-gh" edge="1" parent="1" source="f-gh-dispatch" style="html=1;endArrow=classic;strokeColor=#1E88E5;strokeWidth=2" target="f-gh-api">
          <mxGeometry relative="1" as="geometry" />
