        <mxCell id="s-ad6-note" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;fontSize=11;align=left;spacing=8;spacingLeft=12;fontStyle=0" value="AD-6: deterministic ≠ question-to-agent&#xa;— Fast (&lt; 200 ms P95), free, safe to call repeatedly&#xa;— Never calls an LLM. Never hallucinates.&#xa;— Does NOT interrupt the agent or burn a turn&#xa;— For natural-language questions, see bgagent ask (Phase 2)" vertex="1">
          <mxGeometry height="140" width="800" x="200" y="720" as="geometry" />
        </mxCell>
        <mxCell id="s-safety" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#546E7A;fontSize=11;align=left;spacing=8;spacingLeft=12" value="Concurrency safety&#xa;&#xa;• StatusFn reads from the same TaskEventsTable the agent writes to.&#xa;• Eventually-consistent reads are OK — snapshot may lag by milliseconds,&#xa;  never stale by more than one poll window.&#xa;• Multiple concurrent readers (CLI + Slack bot + web UI) are fine:&#xa;  DDB scales horizontally; no locking or coordination." vertex="1">
          <mxGeometry height="190" width="800" x="200" y="900" as="geometry" />
        </mxCell>
        <mxCell id="s-perf" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F1F8E9;strokeColor=#558B2F;fontSize=11;align=left;spacing=8;spacingLeft=12" value="Performance budget&#xa;&#xa;• DDB GetItem on TaskTable: ~5 ms P95&#xa;• DDB Query last N events: ~10 ms P95 (N ≤ 20)&#xa;• Template render: &lt; 1 ms&#xa;• API Gateway + Lambda cold-path: ~80 ms&#xa;—&#xa;P95 end-to-end: &lt; 200 ms" vertex="1">
          <mxGeometry height="190" width="800" x="200" y="1110" as="geometry" />
        </mxCell>
        <mxCell id="t-cli" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#3F51B5;fontSize=12;fontStyle=1;spacing=6" value="bgagent CLI&#xa;trace download abc123 [-o file]" vertex="1">
