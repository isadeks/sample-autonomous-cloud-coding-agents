        <mxCell id="t-se2-label" parent="1" style="text;html=1;align=center;fontSize=10;fontStyle=2;strokeColor=none;fillColor=none;" value="stream bytes (no decompression in Lambda)" vertex="1">
          <mxGeometry height="30" width="260" x="1646" y="460" as="geometry" />
        </mxCell>
        <mxCell id="t-lifecycle" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#558B2F;fontSize=11;align=left;spacing=8;spacingLeft=12" value="--trace lifecycle (opt-in per task)&#xa;&#xa;1. User runs: bgagent submit --trace &quot;fix the auth bug&quot;&#xa;2. Task record stores trace_enabled=true&#xa;3. Agent&#39;s ProgressWriter raises preview truncation 200 → 4 KB (§10.1)&#xa;4. On task completion, agent uploads full trajectory (SDK message log,&#xa;   tool I/O, hook callbacks) to S3 as gzipped NDJSON&#xa;5. Agent emits trajectory_uploaded milestone with s3_uri&#xa;6. CLI surfaces the URI at end of watch / status&#xa;7. User runs bgagent trace download &lt;task_id&gt; to fetch&#xa;&#xa;Storage:&#xa;— s3://&lt;bucket&gt;/traces/&lt;user_id&gt;/&lt;task_id&gt;.jsonl.gz&#xa;— 7-day lifecycle TTL&#xa;— User-scoped prefix isolates across tenants" vertex="1">
          <mxGeometry height="370" width="1012" x="1260" y="570" as="geometry" />
        </mxCell>
        <mxCell id="t-when" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;fontSize=11;align=left;spacing=8;spacingLeft=12;fontStyle=0" value="When to use --trace (§10.2)&#xa;&#xa;• Reproducible failure modes during development&#xa;• Customer-reported &quot;agent did the wrong thing&quot; incidents&#xa;• Reward-hacking / hallucination audits&#xa;&#xa;NOT intended for routine observability — that&#39;s what watch and&#xa;notifications are for. Default-off keeps storage cost flat across the fleet." vertex="1">
          <mxGeometry height="200" width="1020" x="1260" y="970" as="geometry" />
        </mxCell>
        <mxCell id="t-security" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#EF6C00;fontSize=11;align=left;spacing=8;spacingLeft=12;verticalAlign=top;" value="Security — user-scoped prefix + presign + ownership" vertex="1">
          <mxGeometry height="100" width="1020" x="1260" y="1200" as="geometry" />
        </mxCell>
        <mxCell id="t-security-text" parent="1" style="text;html=1;align=left;fontSize=10;strokeColor=none;fillColor=none" value="TraceUrlFn verifies task.user_id matches Cognito claim before presigning.&#xa;Presigned URL TTL 5 min. S3 bucket blocks public access + enforces SSL.&#xa;Output scanners in ProgressWriter redact secrets before upload." vertex="1">
          <mxGeometry height="70" width="990" x="1278" y="1234" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
