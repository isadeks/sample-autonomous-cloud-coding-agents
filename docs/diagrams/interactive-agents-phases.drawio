        <mxCell id="gh-save-prev-label" parent="1" style="text;html=1;align=center;fontSize=11;strokeColor=none;fillColor=#FFFFFF;fontFamily=Courier New" value="saveCommentState — UpdateItem SET github_comment_id=:new  ConditionExpression: github_comment_id = :prev  (guards 404-race orphans)" vertex="1">
          <mxGeometry height="20" width="1000" x="680" y="1478" as="geometry" />
        </mxCell>
        <mxCell id="gh-rationale" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#6A1B9A;fontSize=11;align=left;spacing=8;spacingLeft=12" value="Why no If-Match / ETag (AD-9, §6.4) — validated in PR #52 Scenario 7-extended&#xa;— GitHub&#39;s REST API REJECTS conditional-request headers on PATCH /issues/comments/{id} with HTTP 400: &quot;Conditional request headers are not allowed in unsafe requests unless supported by the endpoint&quot;. The ETag on GET is a cache validator only; the write endpoint does not honor it.&#xa;— DDB Streams with ParallelizationFactor=1 already gives per-task_id ordering for free, and the fanout Lambda is the only writer on its own comment — last-writer-wins is safe because no concurrent writer exists to lose to.&#xa;— Legacy field github_comment_etag is no longer written or read. Items that still carry it from earlier deploys are ignored (DocumentClient passes through unknown fields). No migration required.&#xa;— Non-404 errors (400, 500, IAM, throttling) propagate through routeEvent&#39;s Promise.allSettled → fanout.dispatcher.rejected warn log; the batch continues so other channels dispatch independently." vertex="1">
          <mxGeometry height="180" width="2200" x="120" y="1540" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
