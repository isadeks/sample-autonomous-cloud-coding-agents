{
  "name": "@abca/docs",
  "scripts": {
    "sync": "node scripts/sync-starlight.mjs",
    "dev": "astro dev",
    "start": "astro dev",
    "docs:check": "npm run sync && astro check",
    "docs:build": "npm run sync && astro build",
    "build": "npm run docs:build",
    "preview": "astro preview",
    "security:retire": "retire --path . --severity high"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "jest-junit": "^16",
    "retire": "^5.4.2"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/starlight": "^0.38.2",
    "astro": "6.1.10",
    "typescript": "^6.0.2"
  },
  "main": "lib/index.js",
  "license": "MIT-0",
  "version": "0.0.0",
  "jest": {
    "coverageProvider": "v8",
    "clearMocks": true,
    "collectCoverage": true,
    "coverageReporters": [
      "json",
      "lcov",
      "clover",
      "cobertura",
      "text"
    ],
    "coverageDirectory": "coverage",
    "coveragePathIgnorePatterns": [
      "/node_modules/"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/"
    ],
    "watchPathIgnorePatterns": [
      "/node_modules/"
    ],
    "testMatch": [
      "**/__tests__/**/*.[jt]s?(x)",
      "**/*(*.)@(spec|test).[jt]s?(x)"
    ],
    "reporters": [
      "default",
      [
        "jest-junit",
        {
          "outputDirectory": "test-reports"
        }
      ]
    ]
  },
  "private": true
}
